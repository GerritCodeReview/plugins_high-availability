    },
    {
      "unresolved": false,
      "key": {
        "uuid": "7a06351c_ad2fcaa8",
        "filename": "src/main/java/com/ericsson/gerrit/plugins/highavailability/Configuration.java",
        "patchSetId": 12
      },
      "lineNbr": 91,
      "author": {
        "id": 1003873
      },
      "writtenOn": "2026-03-26T14:10:52Z",
      "side": 1,
      "message": "Yes, Jgroups based forwarding shall also be externalised. However, currently JGroups can also used for peer discovery and we need to expose an extension point for that (`PeerDiscovery`) before fully externalising JGroups.",
      "parentUuid": "90af13bc_ebf65539",
      "range": {
        "startLine": 91,
        "startChar": 4,
        "endLine": 91,
        "endChar": 11
