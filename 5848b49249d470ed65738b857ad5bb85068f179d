      },
      "lineNbr": 71,
      "author": {
        "id": 1003873
      },
      "writtenOn": "2026-03-26T14:10:52Z",
      "side": 1,
      "message": "The NoForwarder avoids NPE until another plugin provides a real implemenation.\n\nWe need to configure in order to keep the default (REST based) unchanged",
      "parentUuid": "1718f92a_86d3f4a2",
      "range": {
        "startLine": 68,
        "startChar": 0,
        "endLine": 71,
        "endChar": 74
