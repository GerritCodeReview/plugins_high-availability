      "side": 1,
      "message": "Would you mind using the generic events-broker for this purpose?\nIt would allow to use any PubSub subsystem rather than being linked to a specific implementation.",
      "revId": "cbd389ca161a125cb544497039b8a4abada464c1",
      "serverId": "173816e5-2b9a-37c3-8a2e-48639d4f1153"
